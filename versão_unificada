class UnifiedCriticAgent:
    def __init__(self, model_name: str = "moonshotai/kimi-k2-thinking"):
        self.model_name = model_name
        
        # O Agente agora possui ferramentas de leitura para também atuar como Analista
        self.tools = {
            "read_project_files": read_project_files
        }
        
        # Instanciamos o ReActAgent com as ferramentas necessárias
        self.agent = ReActAgent(model_name=model_name, tools=self.tools)

    def produce_verified_documentation(self, project_path: str, project_name: str, max_retries: int = 2) -> Dict[str, Any]:
        """
        Gera a documentação (papel de Analista) e imediatamente a critica (papel de Crítico).
        Se a crítica falhar, o agente refaz o trabalho considerando o feedback.
        """
        current_feedback = None
        best_doc = ""
        best_score = -1
        last_review = {}

        for attempt in range(max_retries + 1):
            logger.info(f"--- Ciclo de Geração/Refinamento {attempt + 1}/{max_retries + 1} ---")
            
            # 1. FASE DE GERAÇÃO (Code Analytics)
            prompt = self._build_generation_prompt(project_path, project_name, current_feedback)
            
            # O agente executa a análise usando read_project_files se necessário
            result = self.agent.run(prompt)
            
            # Extração da resposta (compatibilidade com diferentes retornos do ReAct)
            generated_text = result if isinstance(result, str) else result.get("final_answer", str(result))

            # 2. FASE DE CRÍTICA (Critic Original)
            # O próprio agente avalia o que acabou de criar
            review_result = self.review(generated_text, project_path)
            
            score = review_result.get("score", 0)
            approved = review_result.get("approved", False)
            
            # Mantém registro da melhor versão
            if score > best_score:
                best_score = score
                best_doc = generated_text
                last_review = review_result

            if approved:
                logger.info("Documentação aprovada pelo Crítico interno.")
                return {
                    "status": "success",
                    "documentation": generated_text,
                    "review_metrics": review_result,
                    "iterations": attempt + 1
                }
            
            # Se não aprovou, o feedback vira input para a próxima iteração
            current_feedback = review_result.get("feedback", "")
            hallucinations = review_result.get("hallucinations", [])
            
            if hallucinations:
                current_feedback += f"\nALERTA CRÍTICO: Você citou arquivos inexistentes: {hallucinations}. Verifique os caminhos."
            
            logger.warning(f"Qualidade insuficiente ({score}/10). Refinando...")

        # Se esgotar tentativas, retorna a melhor que conseguiu
        return {
            "status": "partial_success",
            "documentation": best_doc,
            "review_metrics": last_review,
            "warning": "Limite de tentativas excedido. Retornando melhor versão disponível."
        }

    def _build_generation_prompt(self, project_path: str, project_name: str, feedback: str = None) -> str:
        """Constrói o prompt de Analista, incorporando feedback se houver."""
        
        base_prompt = f"""
        Você é um Arquiteto de Software Sênior. Sua missão é analisar o projeto '{project_name}' e gerar documentação técnica.
        
        1. Use a ferramenta read_project_files("{project_path}") para ler o código.
        2. Analise fluxo de dados, arquitetura e dependências.
        3. Gere um Markdown técnico completo (Visão Geral, Arquitetura, fluxo Mermaid, etc).
        """
        
        if feedback:
            base_prompt += f"\n\nATENÇÃO: Sua versão anterior foi analisada e recebeu este FEEDBACK:\n'{feedback}'\n\nMelhore a documentação focando nestes pontos."
            
        return base_prompt

